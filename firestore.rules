rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Settings
    match /settings/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && 
        request.resource.data.keys().hasAll(['phoneNumber', 'missedCallSmsTemplate']) &&
        request.resource.data.phoneNumber is string &&
        request.resource.data.missedCallSmsTemplate is string;
    }

    // Call Logs
    match /calls/{userId}/logs/{callId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && 
        isValidId(callId) &&
        request.resource.data.keys().hasAll(['customerNumber', 'timestamp', 'status']) &&
        request.resource.data.customerNumber is string &&
        request.resource.data.status in ['missed', 'responded', 'settled'];
        
      allow update: if isOwner(userId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'notes', 'reviewLinkSent', 'smsSent']);
        
      allow delete: if isOwner(userId);
    }
  }
}
