rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && (request.auth.uid == userId || request.auth.token.email == userId);
    }

    // Relaxed ID check to allow email-based IDs if necessary
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.size() > 0;
    }

    // 0.2 Health Check
    match /test/connection {
      allow read: if true;
    }

    // 1. Settings (User Profiles)
    match /settings/{userId} {
      function isValidSettings(data) {
        return (data.get('phoneNumber', '') is string) && 
               (data.get('missedCallSmsTemplate', '') is string);
      }

      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidSettings(request.resource.data);
      allow update: if isOwner(userId) && isValidSettings(request.resource.data);
    }

    // 2. Call Logs
    match /calls/{userId}/logs/{logId} {
      function isValidLog(data) {
        return (data.get('customerNumber', '') is string) &&
               (data.get('status', 'missed') in ['missed', 'responded', 'settled']);
      }

      allow read: if isOwner(userId);
      
      allow create: if isOwner(userId) && 
        isValidId(logId) &&
        isValidLog(request.resource.data);

      allow update: if isOwner(userId) && (
        // Allow updating any fields from the dashboard
        request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'status', 'notes', 'reviewLinkSent', 'smsSent', 'rating', 
          'gatekeepingStep', 'customerName', 'lastMessage'
        ])
      );

      allow delete: if isOwner(userId);
    }
  }
}
