rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && (request.auth.uid == userId || request.auth.token.email == userId);
    }

    // Relaxed ID check to allow email-based IDs if necessary
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.size() > 0;
    }

    // 0.2 Health Check
    match /test/connection {
      allow read: if true;
    }

    // 0.2 Health Check
    match /test/connection {
      allow read: if true;
    }

    // 1. Settings (User Profiles)
    match /settings/{userId} {
      function isValidSettings(data) {
        return (data.get('phoneNumber', '') is string) && 
               (data.get('missedCallSmsTemplate', '') is string);
      }

      // Temporarily allowing read for the backend webhook to find the user
      allow read: if true;
      allow create: if isOwner(userId) && isValidSettings(request.resource.data);
      allow update: if isOwner(userId) && isValidSettings(request.resource.data);
    }

    // 2. Call Logs
    match /calls/{userId}/logs/{logId} {
      function isValidLog(data) {
        return (data.get('customerNumber', '') is string) &&
               (data.get('status', 'missed') in ['missed', 'responded', 'settled']);
      }

      // Temporarily allowing read and write for the backend webhook
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if isOwner(userId);
    }
  }
}
